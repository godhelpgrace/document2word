# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_BASE_DIR=./storage_data
UPLOAD_DIR=./storage_data/uploads
RESULT_DIR=./storage_data/results

# File retention (hours), 0 = keep forever
FILE_RETENTION_HOURS=24

# API
API_HOST=0.0.0.0
API_PORT=8000

# OCR
OCR_LANG=ch
OCR_USE_GPU=false

# Processing
RENDER_DPI=200
TEXT_CHAR_THRESHOLD=50
IMAGE_COVERAGE_THRESHOLD=0.5
